CF_PROJECT_DIR := $(abspath $(CF_CFG_DIR)/..)
CF_SHARED_DIR := $(abspath $(CF_CFG_DIR)/../../shared)

include $(CF_SHARED_DIR)/lbm-core/Make.package

VPATH += $(LBM_CORE_DIR)

CEXE_sources += main.cpp
CEXE_sources += $(LBM_CORE_SRC_NAMES)

CEXE_headers += $(LBM_CORE_HDRS)

CXXFLAGS += $(addprefix -I,$(LBM_CORE_INCLUDE_DIRS))
